{
    "name": "genesys",
    "version": "1.0.0",
    "description": "",
    "main": "index.js",
    "scripts": {
        "prepare": "husky",
        "lint": "npm run lint:biome && npm run lint:eslint",
        "lint:fix": "npm run lint:biome:fix && npm run lint:eslint:fix",
        "lint:biome": "biome check .",
        "lint:biome:fix": "biome check . --write",
        "lint:eslint": "eslint src/tests playwright.config.ts --max-warnings=0",
        "lint:eslint:fix": "eslint src/tests playwright.config.ts --max-warnings=0 --fix",
        "format": "biome format . --write",
        "typecheck": "tsc --noEmit",
        "check": "npm run typecheck && npm run lint",
        "check:all": "npm run check && npm run test:raw",
        "precommit": "lint-staged && npm run check",
        "pretest": "npm run check",
        "test": "playwright test",
        "test:raw": "playwright test",
        "test:headed": "playwright test --headed",
        "test:ui": "playwright test --ui",
        "ci": "npm run check:all"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "commonjs",
    "lint-staged": {
        "*.{ts,tsx,mts,cts}": ["biome check --write"]
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@biomejs/biome": "^1.9.4",
        "@playwright/test": "^1.61.1",
        "@types/node": "^26.1.1",
        "@typescript-eslint/eslint-plugin": "8.64.0",
        "@typescript-eslint/parser": "8.64.0",
        "eslint": "^10.7.0",
        "eslint-plugin-playwright": "^2.10.5",
        "globals": "^17.7.0",
        "husky": "^9.1.7",
        "lint-staged": "^17.1.0",
        "typescript": "^6.0.3"
    }
}
