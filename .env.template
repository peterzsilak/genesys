# Test / QA user credentials
TEST_USER_NAME=        # app login username
TEST_USER_PASSWORD=    # app login password

# ── Playwright MCP ─────────────────────────────────────────────────────────────
# No credentials required. Configured via .mcp.json (playwright-test server).

# ── GitHub ─────────────────────────────────────────────────────────────────────
# GITHUB_TOKEN          → used by the `gh` CLI
# GITHUB_PERSONAL_ACCESS_TOKEN → used by the .mcp.json `github` MCP server
GITHUB_TOKEN=                      # your GitHub PAT (gh CLI)
GITHUB_PERSONAL_ACCESS_TOKEN=      # your GitHub PAT (MCP server — can be the same token)
